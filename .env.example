# --- Backend (FastAPI) ---
MIDI_MAPPER_DB_PATH=./midi_map.db
MIDI_MAPPER_MAX_NOTE=119

# Optional: how often we poll MIDI ports (seconds)
MIDI_MAPPER_WS_POLL_INTERVAL=0.01

# Optional: CORS origin if you want to lock it down later
MIDI_MAPPER_CORS_ORIGINS=*

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765
NEXT_PUBLIC_MIDI_MAX_NOTE=119
