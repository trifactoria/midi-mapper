# ~/.config/systemd/user/midi-mapper.service
# Make sure to update this to actual paths if necessary
[Unit]
Description=MIDI Mapper Bridge
After=network.target

[Service]
WorkingDirectory=/home/andy/projects/midi-mapper
Environment=MIDI_MAPPER_DB_PATH=/home/andy/projects/midi-mapper/midi_map.db
ExecStart=/home/andy/projects/midi-mapper/start
Restart=always
RestartSec=1

[Install]
WantedBy=default.target
